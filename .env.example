# Copy this to .env and fill in real values. Never commit .env with real
# secrets. Anything WITHOUT a VITE_ prefix is server-only and never reaches
# the browser bundle — that's deliberate for every secret key below.

# --- Supabase (existing) ---
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_PROJECT_ID=
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=

# Supabase project settings -> API -> service_role key. Required for the
# payment webhooks (src/routes/api/webhooks/*) and payment initiation
# (src/lib/api/payments.functions.ts) to write payments/orders bypassing
# RLS. This was previously defined in code (client.server.ts) but unused
# and unset — Phase 5 is the first real consumer.
SUPABASE_SERVICE_ROLE_KEY=

# --- Paystack (NGN orders) ---
# Paystack dashboard -> Settings -> API Keys & Webhooks -> Secret Key.
# Also register a webhook pointing to:
#   https://<your-domain>/api/webhooks/paystack
# Paystack signs webhooks with this same secret key (no separate webhook
# secret needed, unlike Stripe).
PAYSTACK_SECRET_KEY=

# --- Stripe (GBP orders) ---
# Stripe dashboard -> Developers -> API keys -> Secret key.
STRIPE_SECRET_KEY=
# Stripe dashboard -> Developers -> Webhooks -> add endpoint:
#   https://<your-domain>/api/webhooks/stripe
# listening for "checkout.session.completed" -> Signing secret goes here.
STRIPE_WEBHOOK_SECRET=

# Base URL of this deployed app, used to build Paystack callback_url and
# Stripe success_url/cancel_url. No trailing slash.
APP_URL=http://localhost:3000
